# --- Database (required) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Frontend (required) ---
FRONTEND_URL=http://localhost:3000

# --- Logging (optional, defaults to "text") ---
LOG_FORMAT=text
# Set to "json" on Cloud Run for Cloud Logging integration

# --- LLM Provider (choose one) ---
# Option 1: Vertex AI on GCP (recommended for production)
LLM_PROVIDER=vertex
VERTEX_PROJECT_ID=peopld-dev
VERTEX_REGION=us-east5
VERTEX_MODEL=claude-sonnet-4-6

# Option 2: Anthropic API Direct (set LLM_PROVIDER=anthropic if using this)
# ANTHROPIC_API_KEY=sk-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Icebreaker Tuning (optional, have sensible defaults) ---
# ICEBREAKER_ENABLED=true
# ICEBREAKER_MAX_TOKENS=1024
# ICEBREAKER_TEMPERATURE=0.7
# ICEBREAKER_TIMEOUT_SECONDS=8.0
